PORT=3002
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/patient_db

# Doctor-service base URL (no trailing slash), used to fetch read-only prescriptions for patients.
# DOCTOR_SERVICE_URL=http://localhost:3003

# Optional shared key for service-to-service integration with doctor-service.
# SERVICE_API_KEY=

# Firebase Storage config for patient report blobs
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SIGNED_URL_EXPIRY_SECONDS=600
