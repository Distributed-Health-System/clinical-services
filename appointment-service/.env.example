PORT=3004
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/appointment_db

# Inter-service HTTP clients (native fetch — no @nestjs/axios required)
# Local development: use localhost with the service's local port
# Kubernetes (in-cluster): use the k8s Service DNS name (service-name:port)
TELEMEDICINE_SERVICE_URL=http://localhost:3005
# TELEMEDICINE_SERVICE_URL=http://telemedicine-service:3005  # k8s in-cluster DNS

PAYMENT_SERVICE_URL=http://localhost:3006
# PAYMENT_SERVICE_URL=http://payment-service:3006  # k8s in-cluster DNS

# Doctor Service — availability validation and free-slot queries (DoctorClient)
DOCTOR_SERVICE_URL=http://localhost:3003
# DOCTOR_SERVICE_URL=http://doctor-service:3003  # k8s in-cluster DNS

# Shared inter-service API key for Doctor Service integration routes.
# Must match SERVICE_API_KEY in doctor-service .env exactly.
# When set, sent as X-Service-Api-Key header — bypasses user role auth on integration routes.
# Generate a strong random value (e.g. openssl rand -hex 32).
SERVICE_API_KEY=replace-with-a-strong-shared-secret
