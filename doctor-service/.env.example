PORT=3003
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/doctor_db

# Base URL for patient-service (no trailing slash). Required for doctor → patient report views.
# PATIENT_SERVICE_URL=http://localhost:3002

# Optional: allows appointment-service to call /doctors/integration/availability/* with header:
#   X-Service-Api-Key: <same value>
# SERVICE_API_KEY=

# Must match appointment-service slot step (default 30).
# APPOINTMENT_SLOT_STEP_MINUTES=30

# Firebase Storage for doctor profile images
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SIGNED_URL_EXPIRY_SECONDS=600
