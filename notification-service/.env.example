PORT=3007
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/notification_db
SERVICE_API_KEY=replace-with-shared-internal-key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
# SMS (Twilio). When all three are set, SMS is sent for patientPhone / doctorPhone on the payload.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567
